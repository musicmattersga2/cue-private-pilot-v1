# CUE local server
PORT=3001
CUE_PILOT_PASSWORD=
CUE_PILOT_SESSION_SECRET=

# FLEX read-only connector
# Keep the trailing /f5 segment. Never commit the real authentication value.
FLEX_BASE_URL=https://m2.flexrentalsolutions.com/f5
# Prefer a dedicated read-only FLEX token/header. For a short-lived local
# browser-session fallback, use FLEX_AUTH_HEADER=Cookie and keep the cookie only
# in the ignored .env file on the machine running CUE.
FLEX_AUTH_HEADER=
FLEX_AUTH_VALUE=
# Abort any individual FLEX request that stops responding so reconciliation can
# record and skip that document instead of hanging the entire source-first sync.
CUE_FLEX_REQUEST_TIMEOUT_MS=30000

# Verified Music Matters FLEX identifiers. These defaults are already built into
# CUE; list them here only so an installation can document an intentional override.
CUE_FLEX_MMP_QUOTE_DEFINITION_ID=9bfb850c-b117-11df-b8d5-00e08175e43e
CUE_FLEX_CONFIRMED_STATUS_ID=9d67fccc-aee7-11df-b8d5-00e08175e43e
CUE_FLEX_LOCATION_ID=2f49c62c-b139-11df-b8d5-00e08175e43e
CUE_FLEX_CONFIRMED_PAGE_SIZE=50
CUE_FLEX_BASELINE_LOOKBACK_DAYS=30

# Optional probe controls. The live probe remains read-only.
CUE_FLEX_SMOKE_PAGE_SIZE=5
CUE_FLEX_SMOKE_TIMEOUT_MS=20000
